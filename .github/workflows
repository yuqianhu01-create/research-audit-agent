name: Weekly Research Audit Agent

on:
  workflow_dispatch:
    inputs:
      section:
        description: "Briefing section to search"
        required: true
        default: "all"
        type: choice
        options:
          - all
          - academic
          - industry
          - ai-aging
          - ai-apps
      limit:
        description: "Maximum candidates"
        required: true
        default: "8"
  schedule:
    # Monday 09:00 Beijing time = Monday 01:00 UTC
    - cron: "0 1 * * 1"

jobs:
  run-agent:
    runs-on: ubuntu-latest

    steps:
      - name: Check out repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Run Research Agent
        run: python scripts/research_agent.py --section "${{ github.event.inputs.section || 'all' }}" --limit "${{ github.event.inputs.limit || '8' }}"

      - name: Run Audit Agent
        run: python scripts/audit_agent.py --input data/candidates.json

      - name: Prepare Website Candidate Records
        run: python scripts/publish_agent.py --input data/audit_report.json --issue next --include-needs-review

      - name: Upload agent output
        uses: actions/upload-artifact@v4
        with:
          name: agent-output
          path: |
            data/candidates.json
            data/audit_report.json
            data/website_candidates.json
            data/published_registry.json
